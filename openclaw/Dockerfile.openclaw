FROM golang:1.26-bookworm AS agent-builder

WORKDIR /src

COPY go.mod go.sum ./
ENV GOPROXY=https://goproxy.cn,direct
RUN go mod download

COPY cmd ./cmd
COPY internal ./internal

# BuildKit 多架构构建时注入 TARGET*；与最终镜像架构一致（勿写死 amd64）
ARG TARGETOS=linux
ARG TARGETARCH
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} go build -o /out/openclaw-agent ./cmd/openclaw-agent

FROM node:22-bookworm-slim AS node-runtime

FROM lscr.io/linuxserver/webtop:ubuntu-kde

ENV PUID=1000
ENV PGID=1000
ENV TZ=Asia/Shanghai

LABEL shm_size="1gb"

RUN apt-get update \
  && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    ca-certificates \
    libnotify-bin \
  && rm -rf /var/lib/apt/lists/*

COPY --from=node-runtime /usr/local /usr/local

RUN npm install -g openclaw@v2026.4.12
RUN npm install -g clawhub@0.9.0

COPY defaults-template/.config /defaults/.config
# Seed the runtime template under /defaults so the first /config sync gets the
# tracked OpenClaw config plus any files the image expects to manage.
COPY defaults-template/.openclaw /defaults/.openclaw
COPY config/openclaw-agent /defaults/openclaw-agent
COPY --from=agent-builder /out/openclaw-agent /usr/local/bin/openclaw-agent
COPY scripts/openclaw-agent-run /etc/services.d/openclaw-agent/run
COPY scripts/openclaw-agent-finish /etc/services.d/openclaw-agent/finish

# set ictmsg
COPY out/openclaw-ictmsg-2026.4.17.tgz /etc/ictclaw/openclaw-ictmsg-2026.4.17.tgz

# Preinstall the DingTalk channel so its channel id validates before the
# agent's first startup reconciliation.
RUN sed -i 's/\r$//' /etc/services.d/openclaw-agent/run \
  && sed -i 's/\r$//' /etc/services.d/openclaw-agent/finish \
  && chmod +x /etc/services.d/openclaw-agent/run \
  && chmod +x /etc/services.d/openclaw-agent/finish \
  && chmod +x /usr/local/bin/openclaw-agent \
  && HOME=/defaults openclaw plugins install @dingtalk-real-ai/dingtalk-connector@0.8.13 \
  && HOME=/defaults openclaw plugins install @wecom/wecom-openclaw-plugin@2026.4.8 \
  && HOME=/defaults openclaw plugins install @ct2/changewayguard@6.8.29 --dangerously-force-unsafe-install \
  && HOME=/defaults openclaw plugins install /etc/ictclaw/openclaw-ictmsg-2026.4.17.tgz \
  && chown -R abc:abc /defaults/.openclaw \
  && chown -R abc:abc /defaults/.config \
  && mkdir -p /var/lib/openclaw-agent /var/log/openclaw-agent /etc/openclaw-agent

EXPOSE 3000 3001
