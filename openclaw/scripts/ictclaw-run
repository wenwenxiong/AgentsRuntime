#!/usr/bin/with-contenv bash
set -euo pipefail

ICTCLAW_USER="abc"
ICTCLAW_BIN="/etc/ictclaw/ictclaw"
ICTCLAW_DATA_DIR="/var/lib/ictclaw"
ICTCLAW_LOG_DIR="/var/log/ictclaw"
ICTCLAW_CONFIG_DIR="/etc/ictclaw/configs"
ICTCLAW_CONFIG_FILE="$ICTCLAW_CONFIG_DIR/config.yaml"

mkdir -p "$ICTCLAW_DATA_DIR" "$ICTCLAW_LOG_DIR" "$ICTCLAW_CONFIG_DIR"

if [ ! -f "$ICTCLAW_CONFIG_FILE" ]; then
  cp /defaults/ictclaw/config.yaml "$ICTCLAW_CONFIG_FILE"
fi

chown -R "$ICTCLAW_USER:$ICTCLAW_USER" "$ICTCLAW_DATA_DIR" "$ICTCLAW_LOG_DIR" "$ICTCLAW_CONFIG_DIR"
chmod 0755 "$ICTCLAW_DATA_DIR" "$ICTCLAW_LOG_DIR" "$ICTCLAW_CONFIG_DIR"
chmod 0644 "$ICTCLAW_CONFIG_FILE"

exec "$ICTCLAW_BIN"
